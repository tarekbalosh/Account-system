{
  "version": 2,
  "builds": [
    {
      "src": "backend/src/vercel.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["prisma/**", "backend/prisma/**"]
      }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/src/vercel.ts"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ]
}
